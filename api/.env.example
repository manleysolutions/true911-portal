DATABASE_URL=postgresql+asyncpg://true911:true911@localhost:5432/true911
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=["http://localhost:5173"]
APP_MODE=demo
INTEGRATION_WEBHOOK_SECRET=local-dev-secret-change-in-prod
ZOHO_WEBHOOK_SECRET=local-zoho-secret-change-in-prod
INTEGRATION_ALLOWED_SOURCES=zoho,qb
INTEGRATION_HMAC_SKEW_SECONDS=300
TRUE911_BOOTSTRAP_ADMIN_PASSWORD=localdev-change-in-prod
ALLOW_PUBLIC_REGISTRATION=true
SEED_DEMO=true

# ── Verizon ThingSpace ─────────────────────────────────────────────
# Auth mode — pick ONE of:
#   oauth_client_credentials   (client_id + client_secret)
#   api_key_secret_token       (API key + secret + token from ThingSpace key mgmt)
#   legacy_short_key_secret    (short key + secret for older accounts)
#   username_password_session  (username + password session login)
VERIZON_THINGSPACE_AUTH_MODE=
VERIZON_THINGSPACE_BASE_URL=https://thingspace.verizon.com/api
# OAuth token endpoint path (appended to BASE_URL). Common paths:
#   /ts/v1/oauth2/token   (default — ThingSpace v1)
#   /oauth2/token          (if your account uses the root path)
VERIZON_THINGSPACE_OAUTH_TOKEN_PATH=/ts/v1/oauth2/token
VERIZON_THINGSPACE_ACCOUNT_NAME=

# --- Mode: oauth_client_credentials ---
VERIZON_THINGSPACE_CLIENT_ID=
VERIZON_THINGSPACE_CLIENT_SECRET=

# --- Mode: api_key_secret_token ---
# (from ThingSpace > Key Management > API key, API secret, and Token)
# These are exchanged for an OAuth2 access_token via the token endpoint.
# M2M requests then send both Authorization: Bearer and the app token header.
VERIZON_THINGSPACE_API_KEY=
VERIZON_THINGSPACE_API_SECRET=
VERIZON_THINGSPACE_API_TOKEN=
# Header name for the app token on M2M requests (default: VZ-M2M-Token)
# Some accounts require "App-Token" instead.
VERIZON_THINGSPACE_APP_TOKEN_HEADER=VZ-M2M-Token

# --- Mode: legacy_short_key_secret ---
VERIZON_THINGSPACE_SHORT_KEY=
VERIZON_THINGSPACE_SHORT_SECRET=

# --- Mode: username_password_session ---
VERIZON_THINGSPACE_USERNAME=
VERIZON_THINGSPACE_PASSWORD=
